<% layout("/layouts/boilerplate") %>
<body>
  <div class="container mt-4">
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
      <div class="col">
        <div class="card text-center mb-3 h-100">
          <div class="card-body d-flex flex-column flex-wrap">
            <h5 class="card-title">Internships</h5>
            <p class="card-text">
              Apply to internships that help you learn, grow, and prepare for
              your future career.
            </p>
            <a
              href="/opportunity/category?q=Internship"
              class="btn btn-primary mt-auto text-center ms-auto me-auto align-self-start"
              >Search</a
            >
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card text-center mb-3 h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">Hackathon</h5>
            <p class="card-text">
              Join hackathons to build innovative solutions, collaborate with
              others, and sharpen your technical skills.
            </p>
            <div class="mt-auto">
              <a
                href="/opportunity/category?q=Hackathon"
                class="btn btn-primary mt-auto"
                >Search</a
              >
            </div>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card text-center mb-3 h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">Placement</h5>
            <p class="card-text">
              Apply to placement opportunities that help you grow, gain
              experience, and start your professional career.
            </p>
            <div class="mt-auto">
              <a
                href="/opportunity/category?q=Placement"
                class="btn btn-primary"
                >Search</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
